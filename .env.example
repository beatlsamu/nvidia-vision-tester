# ── NVIDIA API ──────────────────────────────────────────────────────────────
# Get your key at: https://integrate.api.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# These VITE_ vars are embedded in the frontend bundle at build time
VITE_NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_MODEL=meta/llama-4-maverick-17b-128e-instruct
VITE_API_URL=/nvidia/v1/chat/completions

# ── Server ───────────────────────────────────────────────────────────────────
# PORT is set automatically by Render — don't touch it there
PORT=3001
